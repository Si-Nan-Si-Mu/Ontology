# 复制为 .env 后按需修改（不要将 .env 提交到版本库）
NEO4J_URI=bolt://127.0.0.1:7687
# 用户名：本地用 NEO4J_USER；Neo4j Aura 导出文件里多为 NEO4J_USERNAME（二选一即可）
NEO4J_USER=neo4j
NEO4J_PASSWORD=please-change
# 留空则使用服务器默认库（Neo4j 5 社区版通常为 neo4j）
NEO4J_DATABASE=

# 本机微信（wx-cli）直连：设为 true 后开放 GET /api/v1/wechat/sessions 等（子进程，勿在公网暴露后端）
WX_CLI_ENABLED=false
WX_CLI_COMMAND=wx
WX_CLI_TIMEOUT_SEC=120

# 本机微信 wxid（导出 JSON 里 sender 为空 = 本机发言）。分析不同私聊对象时请选对方昵称/会话名，主键用导出根字段 username
# WX_LOCAL_USERNAME=wxid_your_account_here

# 单份聊天 JSON 最大原始消息条数（规范化后一次性做人格摘要）；默认 100000，最大 500000
# WX_CHAT_IMPORT_MAX_MESSAGES=100000

# DeepSeek（OpenAI 兼容 API）：https://api-docs.deepseek.com/zh-cn/
# 配置后微信人格导入将自动用 LLM 增强摘要/MBTI/九型等（失败则回退启发式）
DEEPSEEK_ENABLED=false
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SEC=120
# 思考模式（对应文档 thinking.type=enabled；更慢、更贵）
DEEPSEEK_THINKING_ENABLED=false
